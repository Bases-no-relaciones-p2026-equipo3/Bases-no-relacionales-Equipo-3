# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo a .env y rellena los valores según tu rol en la sesión.
# El archivo .env está en .gitignore — nunca se sube al repositorio.
#
# MODO DISTRIBUIDO (RED LOCAL): Reemplaza "localhost" con el nombre .local
# de la computadora que tiene ese servicio.
#
# Para obtener tu nombre, corre 'hostname' en la terminal.
# Ejemplo: si tu hostname es "CompuAndre", usa "CompuAndre.local".
#
# Roles actuales:
#   Andre    → CompuAndre.local  (Cassandra + Ingesta)
#   Compañer@ → Nombre.local      (Spark + Master)
# ─────────────────────────────────────────────────────────────────────────────

OPENSKY_CLIENT_ID     = tu-client-id
OPENSKY_CLIENT_SECRET = tu-client-secret

# ── Cassandra ─────────────────────────────────────────────────────────────────
# IP WireGuard de la máquina que corre Cassandra (Rol A — Andre: 10.15.20.18)
# Si eres tú quien tiene Cassandra corriendo localmente: dejar como localhost
CASSANDRA_HOST     = localhost
CASSANDRA_PORT     = 9041
CASSANDRA_USER     = cassandra
CASSANDRA_PASSWORD = cassandra
# Los 3 nodos de Cassandra corren en la MISMA máquina (puertos 9041/9042/9043).
# El driver Python se conecta a CASSANDRA_HOST:CASSANDRA_PORT y descubre
# los demás nodos automáticamente vía el protocolo gossip de Cassandra.
# No es necesario listar los 3 puertos manualmente.

# ── Neo4j ─────────────────────────────────────────────────────────────────────
# IP WireGuard de la máquina que corre Neo4j (Rol B — Víctor: 10.15.20.12)
# Si eres tú quien tiene Neo4j corriendo localmente: dejar como localhost
NEO4J_HOST     = localhost
NEO4J_PORT     = 7687
NEO4J_USER     = neo4j
NEO4J_PASSWORD = password

# ── Spark ─────────────────────────────────────────────────────────────────────
# SPARK_MASTER:
#   local[*]                     → Spark corre en esta misma máquina (modo desarrollo)
#   spark://10.15.20.13:6077     → Cluster Docker de Regina (NOTA: puerto 6077, no 7077)
SPARK_MASTER     = local[*]
SPARK_DRIVER_MEM = 2g
SPARK_EXEC_MEM   = 2g

# SPARK_DRIVER_HOST:
#   Solo necesario cuando SPARK_MASTER apunta a un cluster remoto (spark://...).
#   Debe ser la IP WireGuard de ESTA máquina para que los workers puedan
#   comunicarse de vuelta con el driver.
#   Dejar comentado si se usa SPARK_MASTER = local[*].
# SPARK_DRIVER_HOST = 10.15.20.13
