# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo a .env y rellena los valores según tu rol en la sesión.
# El archivo .env está en .gitignore — nunca se sube al repositorio.
#
# Uso:
#   Windows PowerShell : copy .env.example .env  → editar .env → uv run python ...
#   Mac/Linux          : cp .env.example .env    → editar .env → uv run python ...
#
# Alternativa sin .env (PowerShell):
#   $env:CASSANDRA_HOST = "10.15.20.18"
#   uv run python ingesta/opensky_to_cassandra.py
# ─────────────────────────────────────────────────────────────────────────────

OPENSKY_CLIENT_ID     = tu-client-id
OPENSKY_CLIENT_SECRET = tu-client-secret

# ── Cassandra ─────────────────────────────────────────────────────────────────
# IP de la máquina que tiene el Rol A (Cassandra)
# Si eres tú quien tiene Cassandra: dejar como localhost
CASSANDRA_HOST     = localhost
CASSANDRA_PORT     = 9041
CASSANDRA_USER     = cassandra
CASSANDRA_PASSWORD = cassandra

# ── Neo4j ─────────────────────────────────────────────────────────────────────
# IP de la máquina que tiene el Rol B (Neo4j)
# Si eres tú quien tiene Neo4j: dejar como localhost
NEO4J_HOST     = localhost
NEO4J_PORT     = 7687
NEO4J_USER     = neo4j
NEO4J_PASSWORD = password

# ── Spark ─────────────────────────────────────────────────────────────────────
# Para correr en local sin cluster Spark: dejar como local[*]
# Para correr en cluster: spark://IP_SPARK_MASTER:7077
SPARK_MASTER     = local[*]
SPARK_DRIVER_MEM = 2g
SPARK_EXEC_MEM   = 2g
